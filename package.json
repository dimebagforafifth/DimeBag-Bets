{
  "name": "dimebag-bets",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Points-based sportsbook + casino games on one shared credit/balance core.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "poll:once": "vite-node scripts/poll-odds-once.ts",
    "poll:loop": "vite-node scripts/poll-odds-loop.ts",
    "dev:snapshot": "vite-node scripts/dev-snapshot.ts",
    "worker": "vite-node worker/index.ts",
    "worker:dev": "vite-node --watch worker/index.ts"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@noble/hashes": "^1.8.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@supabase/supabase-js": "^2.108.2",
    "@szhsin/react-menu": "^4.5.2",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  }
}
