{
  "name": "dimebag-bets",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Points-based sportsbook + casino games on one shared credit/balance core.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "poll:once": "vite-node scripts/poll-odds-once.ts",
    "poll:loop": "vite-node scripts/poll-odds-loop.ts",
    "dev:snapshot": "vite-node scripts/dev-snapshot.ts"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^20.10.2",
    "prettier": "^3.8.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
