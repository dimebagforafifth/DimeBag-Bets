{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/data/**",
              "components/sportsbook/**",
              "ui_kits/casino-lobby/**",
              "ui_kits/playstadium-app/**",
              "ui_kits/sportsbook/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Barlow Condensed|Slight Chance|Slight Chance Mono|ECWC Standard|Barlow|Barlow Semi Condensed))/i]",
        "message": "Font not provided by the design system. Available: Barlow Condensed, Slight Chance, Slight Chance Mono, ECWC Standard, Barlow, Barlow Semi Condensed."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|solid|live|neutral)$/]",
        "message": "<Badge> variant must be one of 'gold' | 'solid' | 'live' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BetSelection'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|pick|event|price|key|ref|className|style|children)$/]",
        "message": "<BetSelection> doesn't accept that prop. Declared props: id, pick, event, price."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|text|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'text' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='OddsOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|price|move|key|ref|className|style|children)$/]",
        "message": "<OddsOption> doesn't accept that prop. Declared props: id, label, price, move."
      },
      {
        "selector": "JSXOpeningElement[name.name='OddsOption'] > JSXAttribute[name.name='move'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<OddsOption> move must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GameCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|tag|icon|iconAlt|key|ref|className|style|children)$/]",
        "message": "<GameCard> doesn't accept that prop. Declared props: name, tag, icon, iconAlt."
      },
      {
        "selector": "JSXOpeningElement[name.name='OddsButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|price|selected|move|disabled|key|ref|className|style|children)$/]",
        "message": "<OddsButton> doesn't accept that prop. Declared props: label, price, selected, move, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='OddsButton'] > JSXAttribute[name.name='move'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<OddsButton> move must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|hot|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: label, value, hot."
      },
      {
        "selector": "JSXOpeningElement[name.name='WalletPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:balance|label|weekLabel|weekCents|key|ref|className|style|children)$/]",
        "message": "<WalletPill> doesn't accept that prop. Declared props: balance, label, weekLabel, weekCents."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
