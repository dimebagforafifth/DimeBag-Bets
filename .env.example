# DimeBag-Bets — local environment.
# Copy to `.env.local` (which is gitignored) and fill in real values there.
# With NOTHING set, the app runs fully on localStorage + the built-in MOCK odds
# slate — no Supabase, no SGO quota used. That is the safe default.

# ── Sportsbook odds feed (SGO / SportsGameOdds) ──────────────────────────────
# The poller defaults to MockProvider. It only uses the real SGO feed when BOTH
# of these are set. Leave them UNSET for routine dev so you never burn free-tier
# objects (SGO bills per event returned).
# SGO_LIVE=1
# SPORTS_ODDS_API_KEY_HEADER=your_sgo_api_key   # server-side only — never commit

# ── Supabase (server data layer + the odds cache the book UI reads) ──────────
# Unset → the book reads the built-in mock slate. Set these (and apply
# supabase/migrations) → connectOddsCache() reads the live cache the poller fills.
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_ANON_KEY=<anon-key>
# VITE_SUPABASE_URL=https://<project>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon-key>
# The poll route WRITES the cache, so it needs the service-role key (RLS blocks
# anon writes on the odds tables). Server-side only — never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Scheduled odds polling (keep the cache fresh) — see docs/odds-polling.md ──
# How often the local loop / external pinger polls (seconds; clamped to >=15).
# POLL_INTERVAL_SECONDS=60
# Shared secret guarding /api/poll-odds. When set, the caller must send
# `Authorization: Bearer <CRON_SECRET>` (Vercel Cron sends it automatically).
# Guards BOTH cron routes: /api/poll-odds and /api/run-promos.
# CRON_SECRET=<random-string>

# ── Auth (Supabase Auth; username + password) — see docs/provisioning.md ─────
# Login is by USERNAME; Supabase Auth is email-based, so the adapter maps
# `username` -> `username@<domain>`. Override the domain if you want real,
# routable emails (e.g. to turn on email confirmation). Default is a non-routable
# internal domain. With no Supabase keys the local DEMO auth runs instead.
# SUPABASE_AUTH_EMAIL_DOMAIN=users.dimebag.local

# ── Provably-fair authority (server-side commit-reveal) — see docs/provably-fair-server.md ──
# Server-only secret the /api/fairness route uses to mint server seeds. UNSET → a flagged dev
# fallback secret so local points-only play just works (no backend needed). Set a strong
# random value in production. Never expose to the browser.
# FAIRNESS_SECRET=<random-string>
