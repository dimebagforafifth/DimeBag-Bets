{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "core",
    "games",
    "sportsbook",
    "app",
    "persistence",
    "ledger",
    "sportsdata",
    "manager",
    "org",
    "vip",
    "sound",
    "auth",
    "console",
    "features",
    "lib",
    "components",
    "api",
    "scripts",
    "records",
    "social",
    "pickem",
    "crm",
    "analytics",
    "bonus",
    "p2p",
    "creator",
    "events",
    "gamification",
    "rewards",
    "import",
    "trading",
    "billing",
    "profile",
    "pools",
    "responsible-play",
    "boosts",
    "splits",
    "referrals",
    "worker",
    "brand",
    "experiments"
  ]
}
